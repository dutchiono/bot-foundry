# Foundry itself (@dot_bot_foundry_bot) — NOT for child bot testing
BOT_TOKEN=your_telegram_bot_token

# Discord Foundry (optional — enable cross-platform via /link)
DISCORD_BOT_TOKEN=

# OpenCode Server
# Start with: opencode serve --port 4096
OPENCODE_SERVER_URL=http://127.0.0.1:4096
OPENCODE_SERVER_PASSWORD=

# Optional: Auto-start opencode serve as subprocess
OPENCODE_SERVE_PATH=/usr/local/bin/opencode

# Provider config (used for OpenCode sessions)
PROVIDER_ID=opencode
MODEL_ID=mimo-v2.5-free

# Deployment
DEPLOY_SSH_KEY_PATH=
DEPLOY_DEFAULT_HOST=

# Separate test bot for e2e:rotate — must NOT be @dot_bot_foundry_bot
E2E_TEST_CHILD_BOT_TOKEN=

# Eliza Cloud memory bridge (optional — no-op until both are set)
ELIZA_CLOUD_URL=
ELIZA_CLOUD_API_KEY=
ELIZA_AGENT_ID=foundry
