# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token

# OpenCode Server
# Start with: opencode serve --port 4096
OPENCODE_SERVER_URL=http://127.0.0.1:4096
OPENCODE_SERVER_PASSWORD=

# Optional: Auto-start opencode serve as subprocess
OPENCODE_SERVE_PATH=/usr/local/bin/opencode

# Provider config (used for OpenCode sessions)
PROVIDER_ID=opencode
MODEL_ID=mimo-v2.5-free

# Deployment
DEPLOY_SSH_KEY_PATH=
DEPLOY_DEFAULT_HOST=

# E2E batch testing (scripts/e2e-run-batch.ts, e2e-rotate.ts)
# Spare @BotFather bot — same token rotated into each generated child bot
E2E_TEST_CHILD_BOT_TOKEN=
