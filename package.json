{
  "name": "bot-foundry",
  "version": "0.1.0",
  "private": true,
  "description": "Foundry — Bot Works No. 7. Telegram + Discord bot line.",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run tests/e2e",
    "e2e:batch": "tsx scripts/e2e-run-batch.ts",
    "e2e:rotate": "tsx scripts/e2e-rotate.ts",
    "e2e:rotate:next": "tsx scripts/e2e-rotate.ts --next",
    "e2e:rotate:stop": "tsx scripts/e2e-rotate.ts --stop",
    "e2e:run": "tsx scripts/e2e-run.ts",
    "e2e:rotate:fg": "tsx scripts/e2e-rotate.ts --next --fg",
    "e2e:status": "tsx scripts/e2e-status.ts",
    "prebuild": "npm run typecheck && npm run test",
    "docker:build": "docker build -t bot-foundry .",
    "docker:run": "docker compose up -d",
    "docker:logs": "docker compose logs -f",
    "docker:stop": "docker compose down",
    "stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-all.ps1",
    "reset": "powershell -ExecutionPolicy Bypass -File scripts/stop-all.ps1 -Reset",
    "start:all": "powershell -ExecutionPolicy Bypass -File scripts/start-all.ps1",
    "ci": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.0.0",
    "discord.js": "^14.18.0",
    "dotenv": "^16.4.7",
    "telegraf": "^4.16.3",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  }
}
